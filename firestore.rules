// firestore.rules
// Deploy: firebase deploy --only firestore:rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Products: public read, NO client writes (all writes via backend only)
    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }

    // Admin users: fully locked down
    match /admin_users/{uid} {
      allow read, write: if false;
    }

    // Analytics: public read, no client writes
    match /analytics/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // Catch-all: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
