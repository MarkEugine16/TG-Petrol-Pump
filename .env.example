# ─────────────────────────────────────────────────────────
# TG Petrol Pump Trading — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# JWT — use a random 64-char string in production
JWT_SECRET=change_this_to_a_very_long_random_secret_key_minimum_64_chars
JWT_EXPIRES_IN=8h

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# Firebase
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
# Path to downloaded service account key JSON
FIREBASE_SERVICE_ACCOUNT_KEY=./serviceAccountKey.json
# Firebase Web API key (for client-side Auth REST verification)
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# Admin seed email (must exist in Firebase Auth)
ADMIN_EMAIL=admin@tgpetrol.com

# Upload limits (bytes)
MAX_IMAGE_SIZE_MB=5
MAX_VIDEO_SIZE_MB=100

# Rate limiting
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
LOGIN_RATE_LIMIT_MAX=10
API_RATE_LIMIT_WINDOW_MINUTES=1
API_RATE_LIMIT_MAX=120
